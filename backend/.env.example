# Supabase PostgreSQL connection string (from Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase project URL (from Supabase → Settings → API)
SUPABASE_URL=https://[PROJECT-REF].supabase.co

# For local dev seed data — set to your Supabase user UUID (leave unset for auto dev UUID)
SEED_USER_ID=

# IOL credentials (stored per-user via /integrations/iol/connect)
# IOL_USERNAME=
# IOL_PASSWORD=

# Anthropic (optional, for AI recommendations)
ANTHROPIC_API_KEY=
