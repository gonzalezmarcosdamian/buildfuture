{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/portfolio(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/budget(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/integrations(.*)",
      "dest": "api/index.py"
    }
  ]
}
